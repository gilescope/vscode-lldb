{
    "name": "vscode-bugstalker",
    "displayName": "BugStalker",
    "version": "0.1.0",
    "publisher": "gilescope",
    "description": "Pure-Rust Rust debugger — DWARF-native, vtable-driven dyn Trait recovery, niche-resilient enums, async await-trace.",
    "license": "MIT",
    "icon": "images/bugstalker.png",
    "categories": [
        "Debuggers"
    ],
    "keywords": [
        "rust",
        "debugger",
        "BugStalker",
        "DWARF",
        "DAP"
    ],
    "private": true,
    "repository": {
        "type": "git",
        "url": "https://github.com/gilescope/vscode-lldb.git"
    },
    "engines": {
        "vscode": "^1.74.0"
    },
    "dependencies": {
        "string-argv": "^0.3.1"
    },
    "devDependencies": {
        "@types/vscode": "^1.74.0",
        "@types/node": "^18.0.0",
        "ts-loader": "^9.4.0",
        "typescript": "^5.0.0",
        "webpack": "^5.88.0",
        "webpack-cli": "^5.1.0"
    },
    "scripts": {
        "vscode:prepublish": "npm run -S build",
        "build": "webpack --mode production",
        "watch": "webpack --mode development --watch",
        "typecheck": "tsc --noEmit -p extension/tsconfig.json"
    },
    "main": "out/extension.js",
    "activationEvents": [
        "onDebug",
        "onDebugResolve:bugstalker"
    ],
    "contributes": {
        "languages": [],
        "breakpoints": [
            {
                "language": "rust"
            }
        ],
        "configuration": {
            "type": "object",
            "title": "BugStalker",
            "properties": {
                "bugstalker.executable": {
                    "description": "Path to the BugStalker binary used as the DAP adapter. Defaults to looking up `bugstalker` on the system PATH.",
                    "default": "bugstalker",
                    "type": "string",
                    "scope": "resource"
                },
                "bugstalker.logFile": {
                    "description": "Optional path. When set, BugStalker writes adapter diagnostics here (passed to the binary as `--dap-log-file`).",
                    "type": "string",
                    "scope": "resource"
                },
                "bugstalker.adapterEnv": {
                    "description": "Extra environment variables for the spawned BugStalker process and for `cargo` invocations driven by the `cargo` block.",
                    "type": "object",
                    "patternProperties": {
                        ".*": {
                            "type": "string"
                        }
                    },
                    "default": {},
                    "scope": "resource"
                }
            }
        },
        "debuggers": [
            {
                "type": "bugstalker",
                "label": "BugStalker (Rust)",
                "languages": [
                    "rust"
                ],
                "configurationAttributes": {
                    "launch": {
                        "properties": {
                            "program": {
                                "description": "Path to the Rust binary to debug. Either set this directly, or set `cargo` to have BugStalker build it for you.",
                                "type": "string"
                            },
                            "cargo": {
                                "description": "Cargo invocation parameters. The build artifact path replaces ${cargo:program} (and fills `program` if it's empty).",
                                "type": "object",
                                "properties": {
                                    "args": {
                                        "description": "Cargo command line arguments (e.g. [\"build\", \"--bin=foo\"], or [\"test\", \"--no-run\", \"--lib\"]).",
                                        "type": "array",
                                        "default": [
                                            "build"
                                        ]
                                    },
                                    "filter": {
                                        "description": "Filter applied to compilation artifacts when more than one matches.",
                                        "type": "object",
                                        "properties": {
                                            "name": {
                                                "type": "string"
                                            },
                                            "kind": {
                                                "type": "string"
                                            }
                                        }
                                    }
                                },
                                "required": [
                                    "args"
                                ]
                            },
                            "args": {
                                "description": "Program arguments.",
                                "type": [
                                    "array",
                                    "string"
                                ],
                                "default": []
                            },
                            "cwd": {
                                "description": "Program working directory.",
                                "type": "string",
                                "default": "${workspaceFolder}"
                            },
                            "env": {
                                "description": "Additional environment variables.",
                                "type": "object",
                                "patternProperties": {
                                    ".*": {
                                        "type": "string"
                                    }
                                },
                                "default": {}
                            },
                            "stopOnEntry": {
                                "description": "Stop at the program entry point after launch.",
                                "type": "boolean",
                                "default": false
                            }
                        }
                    },
                    "attach": {
                        "required": [
                            "pid"
                        ],
                        "properties": {
                            "pid": {
                                "description": "Process id to attach to.",
                                "type": [
                                    "integer",
                                    "string"
                                ]
                            }
                        }
                    }
                },
                "configurationSnippets": [
                    {
                        "label": "BugStalker: Launch Rust binary",
                        "body": {
                            "type": "bugstalker",
                            "request": "launch",
                            "name": "${2:Debug}",
                            "program": "^\"\\${workspaceFolder}/${1:target/debug/<your program>}\"",
                            "args": [],
                            "cwd": "^\"\\${workspaceFolder}\""
                        }
                    },
                    {
                        "label": "BugStalker: Debug Cargo binary (build then run)",
                        "body": {
                            "type": "bugstalker",
                            "request": "launch",
                            "name": "${2:Cargo launch}",
                            "cargo": {
                                "args": [
                                    "build",
                                    "--bin=${1:<binary name>}"
                                ]
                            },
                            "args": [],
                            "cwd": "^\"\\${workspaceFolder}\""
                        }
                    },
                    {
                        "label": "BugStalker: Debug Cargo unit tests",
                        "body": {
                            "type": "bugstalker",
                            "request": "launch",
                            "name": "${2:Cargo test}",
                            "cargo": {
                                "args": [
                                    "test",
                                    "--no-run",
                                    "${1:--lib}"
                                ]
                            },
                            "args": [],
                            "cwd": "^\"\\${workspaceFolder}\""
                        }
                    },
                    {
                        "label": "BugStalker: Attach by PID",
                        "body": {
                            "type": "bugstalker",
                            "request": "attach",
                            "name": "${2:Attach}",
                            "pid": "${1:1234}"
                        }
                    }
                ]
            }
        ]
    }
}
