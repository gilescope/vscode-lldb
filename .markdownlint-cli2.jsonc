// Markdown lint config for the BugStalker fork's docs.
//
// Long lines for JSON / cargo snippets and wide tables would lose
// readability if hard-wrapped at 80 cols. Disable line-length and
// let prose wrap to author taste.
{
    "config": {
        "MD013": false
    },
    "globs": [
        "BUGSTALKER.md",
        "README.md"
    ]
}
